# Fish shell environment variables
# Usage: source .env.fish.example (or copy to .env.fish and edit)

# Telegram Bot Token
set -x TG_BOT_TOKEN "your-telegram-bot-token"

# Mailcow Server
set -x SERVER_URL "https://mail.example.com"
set -x X_API_KEY "your-mailcow-api-key"

# Proxy Configuration (optional)
# set -x PROXY_URL "127.0.0.1:9050"
# set -x PROXY_USERNAME "user"
# set -x PROXY_PASSWORD "pass"
